# dependencies
node_modules/

# Expo
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# Native (generated by prebuild / eject)
/ios/
/android/

# Metro
.metro-health-check*
*.hprof

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*
.env*.local

# typescript
*.tsbuildinfo

# Keystores and signing
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# Bundle artifacts
*.aab
*.apk

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS hidden files
Thumbs.db

# Testing
coverage/

# Lock file is tracked but ignore npm cache
.npm/
