{
  "name": "calendario-plantio",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:apk": "npx expo prebuild --platform android && cd android && ./gradlew assembleRelease --parallel --max-workers=$(nproc) && cp app/build/outputs/apk/release/app-release.apk ../calendario-plantio-$(awk -F'\"' '/\"version\": \".+\"/{ print $4; exit; }' ../app.json).apk && echo '✅ APK na raiz do projeto'"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "date-fns": "^4.4.0",
    "expo": "^56.0.8",
    "expo-async-storage": "^0.0.0",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-image-picker": "~56.0.15",
    "expo-linear-gradient": "~56.0.4",
    "expo-localization": "~56.0.6",
    "expo-media-library": "~56.0.6",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "^56.0.5",
    "i18next": "^26.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-calendars": "^1.1314.0",
    "react-native-dynamic-theme": "^0.3.4",
    "react-native-paper": "^5.15.3",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "hermes-engine": "^0.11.0",
    "typescript": "~6.0.3"
  },
  "private": true
}
