{
  "expo": {
    "name": "Calendário de Plantio",
    "slug": "calendario-plantio",
    "version": "0.2.0-alpha",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2e7d32"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2e7d32"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.juanlews.calendarioplantio",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para registrar o crescimento das plantas.",
          "cameraPermission": "O app precisa acessar a câmera para tirar fotos dos seus plantios."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a043c3f4-bfb2-4944-b476-a407351c97dc"
      }
    },
    "owner": "juanlews"
  }
}
